				<xs:assert test="if (@type = 'I-01')
then ( ((string-length($value) = 13 and matches($value, '[0-9]{7}[ABCDEFGHJKLMNPQRSTVWXYZ][ABDNP][CMNPE][0-9]{3}'))
or (string-length($value) = 8 and matches($value, '[0-9]{7}[ABCDEFGHJKLMNPQRSTVWXYZ]')))
 and (let $num := substring($value,1,7),
      $letters := ('A','B','C','D','E','F','G','H','J','K','L','M','N','P','Q','R','S','T','V','W','X','Y','Z'),
      $x := number(substring($num,1,1))*7 +
        number(substring($num,2,1))*6 +
        number(substring($num,3,1))*5 +
        number(substring($num,4,1))*4 +
        number(substring($num,5,1))*3 +
        number(substring($num,6,1))*2 +
        number(substring($num,7,1))*1,
      $index := ($x mod 23) + 1  return substring($value,8,1) = $letters[$index]))
				else if (@type = 'I-02')
                then (string-length($value)=8 and matches($value,'[0-9]{8}'))
				else if ( @type = 'I-03')
                then matches($value,'^[A-Za-z0-9][A-Za-z0-9-]{4,18}[A-Za-z0-9]$')			
				else if (@type = 'I-04') 
				then matches($value, '^[A-Za-z0-9]{1,30}$')
				else if (@type = 'I-05') 
				then matches($value, '^[A-Za-z0-9]{1,30}$')
				else if (@type = 'I-06') 
				then matches($value, '^[A-Za-z0-9]{1,30}$')
				else false()"/>
